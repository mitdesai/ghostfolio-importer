# --- NAS paths (resolved by docker compose on the Dockge host) ---
APP_PATH=/synology-storage/dockge/ghostfolio-importer
FIDELITY_DROP_PATH=/synology-storage/dockge/ghostfolio-importer/fidelity-drop
ROBINHOOD_DROP_PATH=/synology-storage/dockge/ghostfolio-importer/robinhood-drop
HTTP_EXTERNAL_PORT=8421

# --- Ghostfolio ---
GHOSTFOLIO_URL=http://<DOCKGE-HOST-IP>:3333
GHOSTFOLIO_TOKEN=paste_your_security_token_here
DEFAULT_CURRENCY=USD
TZ=America/Los_Angeles

# --- Account mapping (format: key=uuid:broker) ---
# broker: fidelity | robinhood | manual
# Fidelity accounts get subfolders under FIDELITY_DROP_PATH
# Robinhood accounts get subfolders under ROBINHOOD_DROP_PATH
# Manual accounts only appear in the iOS shortcut
ACCOUNT_MAP=brokerage-fidelity=uuid:fidelity,brokerage-link=uuid:fidelity,brokerage=uuid:robinhood,joint-investment=uuid:robinhood,roth-ira=uuid:robinhood,traditional-ira=uuid:robinhood,hsa-bank=uuid:manual

# --- Delisted symbols (use MANUAL data source, comma-separated) ---
MANUAL_SYMBOLS=TRCH

# --- Drop folder paths (container-side, must match compose volumes) ---
FIDELITY_WATCH_DIR=/fidelity-drop
ROBINHOOD_WATCH_DIR=/robinhood-drop

# --- HTTP endpoint (iOS shortcut) ---
HTTP_PORT=8080
HTTP_TOKEN=paste_openssl_rand_hex_24_here

# --- Internal ---
DB_PATH=/state/dedup.sqlite
LOG_LEVEL=INFO
